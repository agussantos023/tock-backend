// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SystemConfig {
  id                      Int     @id @default(1)
  is_register_blocked Boolean @default(false)
  is_login_blocked        Boolean @default(false)
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  password        String
  storage_limit   BigInt    @default(52428800) // 50MB
  storage_used    BigInt    @default(0)
  is_verified     Boolean   @default(false)
  otp_code        String?   @db.VarChar(4)
  otp_create_at   DateTime  @default(now())
  created_at      DateTime  @default(now())
  last_active_at  DateTime  @default(now())

  songs Song[]
}

model Song {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(50)
  artist        String   @default("Unknown artist") @db.VarChar(50)
  album         String   @default("Single") @db.VarChar(50)
  duration      Int      @default(0)   
  year          Int?     
  order_par     String   @default("AAA") @db.VarChar(3)
  order_impar   String   @default("AAA") @db.VarChar(3)
  file_path     String
  file_size     BigInt
  created_at    DateTime @default(now())

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id       Int

  @@index([user_id, order_par])
  @@index([user_id, order_impar])
}
