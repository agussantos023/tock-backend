{
  "openapi": "3.0.0",
  "info": {
    "title": "Tock Music API",
    "version": "0.4.0",
    "description": "Documentación centralizada en JSON"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Desarrollo"
    }
  ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Iniciar sesión",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "test@test.com" },
                  "password": { "type": "string", "example": "tock123" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login exitoso" },
          "400": { "description": "Error en la petición" }
        }
      }
    }
  }
}
